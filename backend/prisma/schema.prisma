// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Minimal models for quick testing (temporary)

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      String   @default("USER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientes  Cliente[]
}

model Cliente {
  id        Int      @id @default(autoincrement())
  nombre    String
  apellido  String
  email     String   @unique
  telefono  String?
  direccion String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
}

// Other models omitted temporarily to avoid complex referential cycles and enums
// Restore full schema later for production SQL Server migration
